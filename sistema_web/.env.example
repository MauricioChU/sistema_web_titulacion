# Copy this file to .env and adjust values for your environment.
# Rsbuild expone al cliente solo variables que empiezan con `PUBLIC_` o `VITE_`.

# URL base del backend Django (incluye /api).
# Ejemplos:
#   Desarrollo local: http://127.0.0.1:8000/api
#   Staging:          https://api.staging.prointel.pe/api
#   Produccion:       https://api.prointel.pe/api
VITE_API_BASE_URL=http://127.0.0.1:8000/api
