# Copia este archivo a .env y ajusta los valores para tu entorno.

# Seguridad
DJANGO_SECRET_KEY=dev-only-change-me-please
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# CORS (coma-separado). El origen por defecto del front (Rsbuild) es 3000.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Base de datos. SQLite por defecto (0 dependencias).
# Para usar Postgres, define DATABASE_URL en formato:
#   postgres://user:pass@host:5432/dbname
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/prointel

# MongoDB local opcional.
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB_NAME=prointel_mongo
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=3000

# JWT (en minutos y dias).
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7
